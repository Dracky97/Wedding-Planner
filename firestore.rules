rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Authenticated users can read/write their own plan data
    match /plans/{planId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // Public RSVP: anyone with the planId link can read guests and update rsvp/meal only
    match /plans/{planId}/guests/{guestId} {
      allow read: if true;
      allow update: if request.auth == null
        && request.resource.data.keys().hasOnly(['rsvp', 'meal'])
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rsvp', 'meal']);
    }

    // Users manage their own plan associations
    match /users/{userId}/plans/{planAssociationId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Users manage their own user document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read, write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Blogs: public read, admins write
    match /blogs/{blogId} {
      allow read: if true;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Events: public read, admins write
    match /events/{eventId} {
      allow read: if true;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
